# ===========================================
# OFFICELAWYER - Environment Variables
# ===========================================

# -------------------------------------------
# Database Mode (local | turso | auto)
# -------------------------------------------
# local: SQLite محلي للتطوير والاستخدام المحلي
# turso: Turso سحابي للنشر على Vercel/Netlify
# auto: اختيار تلقائي حسب البيئة (افتراضي)
DATABASE_MODE=auto

# -------------------------------------------
# Local SQLite Configuration
# -------------------------------------------
# مسار قاعدة البيانات المحلية (اختياري)
# DATABASE_PATH=file:local.db

# -------------------------------------------
# Turso Cloud Configuration
# -------------------------------------------
# للحصول على هذه القيم:
# 1. أنشئ حساب على https://turso.tech
# 2. أنشئ قاعدة بيانات جديدة
# 3. انسخ URL و Auth Token من لوحة التحكم
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# -------------------------------------------
# Authentication Configuration
# -------------------------------------------
# الرمز الافتراضي لتسجيل الدخول
DEFAULT_PASSCODE=123456

# -------------------------------------------
# Application Configuration
# -------------------------------------------
NODE_ENV=development

# -------------------------------------------
# Platform Detection (Auto-detected)
# -------------------------------------------
# NETLIFY=true
# VERCEL=1
# RENDER=true
